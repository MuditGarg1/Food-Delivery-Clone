# Food Delivery Backend — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/food-del

# JWT secret key (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Stripe secret key (get from stripe.com dashboard)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Frontend URL for CORS & Stripe redirects
FRONTEND_URL=http://localhost:5173

# Port for the backend server
PORT=4000
